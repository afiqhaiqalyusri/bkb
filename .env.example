# ─────────────────────────────────────────────────────────────
#  BKB — Environment Variables (Local Development)
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/bkb
DB_USER=bkb_user
DB_PASSWORD=change_me

# ── JWT (generate with: openssl rand -hex 64) ─────────────────
JWT_SECRET=change_me_to_a_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_64_char_hex_string

# ── CORS & Frontend URL ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend Build ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8081

# ── Mail (optional — leave as placeholder to disable) ────────
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=placeholder
