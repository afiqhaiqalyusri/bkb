# ─────────────────────────────────────────────────────────────
#  BKB — Production Environment Variables (VPS)
#  This file is written automatically by GitHub Actions.
#  The values come from your GitHub Repository Secrets.
#
#  To set secrets: GitHub Repo → Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# host.docker.internal resolves to the VPS host from inside Docker containers
DATABASE_URL=jdbc:postgresql://host.docker.internal:5432/bkb
DB_USER=bkb_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ── JWT Secrets (generate with: openssl rand -hex 64) ─────────
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_VALUE

# ── CORS & URLs ───────────────────────────────────────────────
FRONTEND_URL=https://fyp.afiqhaiqal.my
CORS_ALLOWED_ORIGINS=https://fyp.afiqhaiqal.my
VITE_API_BASE_URL=https://fyp.afiqhaiqal.my

# ── Mail ──────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
